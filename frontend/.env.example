# Backend NestJS API
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_API_KEY=""

# Authentication (NextAuth.js v4)
# Generar con: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Apple Sign In
# https://developer.apple.com → Certificates, Identifiers & Profiles → Keys
# APPLE_ID = Service ID (e.g. com.hireeo.web)
# APPLE_SECRET = JWT generado con el .p8 (next-auth lo construye con las vars APPLE_*)
# Ver: https://next-auth.js.org/providers/apple
APPLE_ID=""
APPLE_SECRET=""

# Microsoft / Azure AD
# https://portal.azure.com → Azure Active Directory → App registrations
# AZURE_AD_TENANT_ID = 'common' permite cuentas personales y empresariales
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID="common"

# Payments (MercadoPago)
# https://www.mercadopago.com/developers/panel
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-..."
MP_ACCESS_TOKEN="APP_USR-..."

# Storage (Vercel Blob)
BLOB_READ_WRITE_TOKEN=""

# Email (Brevo/Sendinblue)
BREVO_API_KEY="xkeysib-..."
BREVO_SENDER_EMAIL="info@tu-dominio.cl"
BREVO_SENDER_NAME="Nombre Sitio"
CONTACT_EMAIL="contacto@tu-dominio.cl"

# AI (Google Gemini)
GEMINI_API_KEY=""

# URL pública de la aplicación (SEO / Sitemap)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

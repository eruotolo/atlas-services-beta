# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (monorepo — cubre raíz, frontend/ y backend/)
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
**/coverage
/frontend/test-results/
/frontend/playwright-report/
/frontend/playwright/.auth/
/frontend/playwright/.cache/

# next.js (cubre frontend/.next y cualquier subpaquete)
**/.next/
**/out/

# production builds
**/build
**/dist

# misc
.DS_Store
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production.remote

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated client
**/generated/prisma
**/prisma/generated

# IDEs
.idea/
.vscode/
.codegraph/

# Internal Tools & Scripts
/scripts/

# Docker — datos persistidos de PostgreSQL
docker-database/postgres-data/

# Prototipo de diseño (referencia, no parte del código fuente)
NuevoHireeoApp/
Nuevo Hireeo App.zip

# Archivos temporales (screenshots, auditorías visuales, etc.)
.tmp/

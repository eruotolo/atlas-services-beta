# ============================================
# VARIABLES DE ENTORNO — PLANTILLA
# ============================================
# Copia este archivo como .env.local y completa los valores.

NODE_ENV=development
PORT=4000

# Base de datos PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT — Genera secretos seguros con: openssl rand -base64 64
JWT_SECRET=""
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET=""
JWT_REFRESH_EXPIRES_IN="30d"

# Frontend URL (para CORS)
FRONTEND_URL="http://localhost:3000"

# API Key — Genera con: openssl rand -hex 32
API_KEY=""

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ServiceLevel {
    BASIC
    PREMIUM
}

enum SponsorCategory {
    SENIOR
    PREMIUM
    STANDARD
}

enum CommentStatus {
    PENDING
    ACTIVE
    DELETED
}

enum InteractionType {
    VIEW_PHONE
    VIEW_EMAIL
    CALL
    WHATSAPP
}

enum SocialMediaType {
    WEBSITE
    FACEBOOK
    INSTAGRAM
    LINKEDIN
    TIKTOK
    TWITTER
    YOUTUBE
    OTHER
}

enum PaymentGateway {
    MERCADOPAGO
    STRIPE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Country {
    id            String         @id @default(uuid())
    code          String         @unique
    name          String
    currency      String
    locale        String
    timezone      String
    gateway       PaymentGateway
    regionLabel   String
    localityLabel String
    active        Boolean        @default(true)
    paymentsEnabled Boolean      @default(true)
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt

    regions       GeoRegion[]
    services      Service[]
    premiumPrices PremiumPrice[]
    sponsors      Sponsor[]
    userRoles     UserRole[]

    @@map("countries")
}

model GeoRegion {
    id        String   @id @default(uuid())
    countryId String
    name      String
    code      String
    active    Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    country    Country       @relation(fields: [countryId], references: [id])
    localities GeoLocality[]
    services   Service[]

    @@unique([countryId, code])
    @@index([countryId])
    @@map("geo_regions")
}

model GeoLocality {
    id        String   @id @default(uuid())
    regionId  String
    name      String
    slug      String
    active    Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    region   GeoRegion @relation(fields: [regionId], references: [id])
    services Service[]

    @@unique([regionId, slug])
    @@index([regionId])
    @@map("geo_localities")
}

model User {
    id        String   @id @default(uuid())
    email     String   @unique
    password  String?
    name      String
    phone     String?
    avatar    String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    services              Service[]
    ratings               Rating[]
    roles                 UserRole[]
    interactions          Interaction[]
    favorites             Favorite[]
    clientConversations   Conversation[] @relation("clientConversations")
    providerConversations Conversation[] @relation("providerConversations")

    @@map("users")
}

model Role {
    id        String   @id @default(uuid())
    name      String   @unique
    active    Boolean  @default(true)
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    users UserRole[]

    @@map("roles")
}

model UserRole {
    id        String   @id @default(uuid())
    userId    String
    roleId    String
    countryId String?
    createdAt DateTime @default(now())

    user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    role    Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
    country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

    @@unique([userId, roleId, countryId])
    @@index([userId])
    @@index([roleId])
    @@index([countryId])
    @@map("user_roles")
}

model ServiceCategory {
    id          String   @id @default(uuid())
    name        String
    slug        String
    icon        String?
    order       Int      @default(0)
    active      Boolean  @default(true)
    countryCode String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    services ServiceCategoryMap[]

    @@unique([slug, countryCode])
    @@map("service_categories")
}

model ServiceCategoryMap {
    id         String   @id @default(uuid())
    serviceId  String
    categoryId String
    createdAt  DateTime @default(now())

    service  Service         @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    category ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

    @@unique([serviceId, categoryId])
    @@index([serviceId])
    @@index([categoryId])
    @@map("service_category_map")
}

model Service {
    id            String       @id @default(uuid())
    userId        String
    countryId     String
    regionId      String?
    localityId    String?
    commune       String
    title         String
    slug          String       @unique
    description   String       @db.Text
    price         Decimal      @db.Decimal(10, 2)
    contactName   String?
    contactEmail  String?
    contactPhone  String?
    mainImage     String?
    images        String[]
    averageRating Decimal?     @db.Decimal(2, 1)
    totalRatings  Int          @default(0)
    featured      Boolean      @default(false)
    active        Boolean      @default(true)
    level         ServiceLevel @default(BASIC)
    startDate     DateTime     @default(now())
    endDate       DateTime
    createdAt     DateTime     @default(now())
    updatedAt     DateTime     @updatedAt

    user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
    country       Country              @relation(fields: [countryId], references: [id])
    region        GeoRegion?           @relation(fields: [regionId], references: [id])
    locality      GeoLocality?         @relation(fields: [localityId], references: [id])
    categories    ServiceCategoryMap[]
    ratings       Rating[]
    subscription  Subscription?
    interactions  Interaction[]
    socialMedia   SocialMedia[]
    favorites     Favorite[]
    conversations Conversation[]

    @@index([countryId])
    @@index([regionId])
    @@index([localityId])
    @@index([commune])
    @@index([userId])
    @@index([averageRating])
    @@index([level])
    @@index([endDate])
    @@index([countryId, level, featured, endDate])
    @@map("services")
}

model Rating {
    id            String        @id @default(uuid())
    serviceId     String
    userId        String
    stars         Int
    comment       String?       @db.Text
    status        CommentStatus @default(PENDING)
    ownerResponse String?       @db.Text
    respondedAt   DateTime?
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt

    service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([serviceId, userId])
    @@index([serviceId])
    @@index([userId])
    @@map("ratings")
}

model Subscription {
    id             String         @id @default(uuid())
    serviceId      String         @unique
    durationMonths Int
    amount         Decimal        @db.Decimal(10, 2)
    currency       String         @default("CLP")
    paymentGateway PaymentGateway @default(MERCADOPAGO)
    paymentMethod  String?
    paymentStatus  String         @default("pending")
    transactionId  String?
    startDate      DateTime       @default(now())
    endDate        DateTime
    active         Boolean        @default(true)
    createdAt      DateTime       @default(now())
    updatedAt      DateTime       @updatedAt

    service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    @@index([serviceId])
    @@index([active])
    @@index([paymentStatus])
    @@map("subscriptions")
}

model Sponsor {
    id           String          @id @default(uuid())
    countryId    String?
    name         String
    level        SponsorCategory
    imageUrl     String
    description  String?         @db.Text
    externalLink String
    startDate    DateTime        @default(now())
    endDate      DateTime
    active       Boolean         @default(true)
    createdAt    DateTime        @default(now())
    updatedAt    DateTime        @updatedAt

    country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

    @@index([countryId])
    @@index([level])
    @@index([active])
    @@map("sponsors")
}

model PremiumPrice {
    id             String   @id @default(uuid())
    countryId      String
    durationMonths Int
    price          Decimal  @db.Decimal(10, 2)
    currency       String
    description    String?
    active         Boolean  @default(true)
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt

    country Country @relation(fields: [countryId], references: [id])

    @@unique([countryId, durationMonths])
    @@index([countryId])
    @@index([active])
    @@map("premium_prices")
}

model Interaction {
    id        String          @id @default(uuid())
    type      InteractionType
    serviceId String
    userId    String?
    metadata  Json?
    createdAt DateTime        @default(now())

    service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

    @@index([serviceId])
    @@index([type])
    @@index([createdAt])
    @@map("interactions")
}

model SocialMedia {
    id        String          @id @default(uuid())
    serviceId String
    type      SocialMediaType
    url       String
    createdAt DateTime        @default(now())
    updatedAt DateTime        @updatedAt

    service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    @@index([serviceId])
    @@map("social_media")
}

// ─── Fase 2: Confianza y Comunicación ─────────────────────────────────────────

model Favorite {
    id        String   @id @default(uuid())
    userId    String
    serviceId String
    createdAt DateTime @default(now())

    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

    @@unique([userId, serviceId])
    @@index([userId])
    @@index([serviceId])
    @@map("favorites")
}

enum MessageSender {
    CLIENT
    PROVIDER
}

model Conversation {
    id            String   @id @default(uuid())
    serviceId     String
    clientId      String
    providerId    String
    lastMessageAt DateTime @default(now())
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt

    service  Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
    client   User      @relation("clientConversations", fields: [clientId], references: [id], onDelete: Cascade)
    provider User      @relation("providerConversations", fields: [providerId], references: [id], onDelete: Cascade)
    messages Message[]

    @@unique([serviceId, clientId])
    @@index([clientId])
    @@index([providerId])
    @@index([lastMessageAt])
    @@map("conversations")
}

model Message {
    id             String        @id @default(uuid())
    conversationId String
    senderId       String
    senderType     MessageSender
    text           String        @db.Text
    read           Boolean       @default(false)
    createdAt      DateTime      @default(now())

    conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

    @@index([conversationId])
    @@index([createdAt])
    @@map("messages")
}

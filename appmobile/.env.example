# Copy to .env.local and fill in values
# iOS Simulator dev: http://localhost:4000
# Android Emulator dev: http://10.0.2.2:4000
# Production: use EAS secrets
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_API_KEY=
# Next.js frontend URL for image uploads (Vercel Blob via /api/upload)
EXPO_PUBLIC_UPLOAD_URL=http://localhost:3000/api/upload
